APP_ENV=dev
APP_NAME=veda-trading-ai
APP_SECRET_KEY=change-me

POSTGRES_DB=veda
POSTGRES_USER=veda
POSTGRES_PASSWORD=veda_password
DATABASE_URL=postgresql+psycopg://veda:veda_password@postgres:5432/veda

REDIS_URL=redis://redis:6379/0
CHROMA_HOST=chroma
CHROMA_PORT=8000

OPENAI_API_KEY=
OPENAI_EXTRACTION_ENABLED=false
OPENAI_EXTRACTION_MODEL=gpt-4.1-mini

BLOG_FEEDS=
BLOG_DISCOVERY_URLS=
BLOG_INGEST_INTERVAL_SECONDS=3600
BLOG_INGEST_LIMIT=20
BLOG_INGEST_ON_START=false

# Semicolon-separated: SYMBOL|timeframe|http(s), file://, or local CSV path
MARKET_DATA_SOURCES=
MARKET_DATA_INGEST_INTERVAL_SECONDS=900
MARKET_DATA_INGEST_LIMIT=10000
MARKET_DATA_INGEST_ON_START=false

ANGELONE_API_KEY=
ANGELONE_CLIENT_CODE=
ANGELONE_PIN=
ANGELONE_TOTP_SECRET=
ANGELONE_CLIENT_LOCAL_IP=127.0.0.1
ANGELONE_CLIENT_PUBLIC_IP=127.0.0.1
ANGELONE_CLIENT_MAC=00:00:00:00:00:00
ANGELONE_HISTORY_DAYS=5

DHAN_CLIENT_ID=
DHAN_ACCESS_TOKEN=
DHAN_PIN=
DHAN_TOTP_SECRET=
DHAN_HISTORY_DAYS=90
DHAN_TOKEN_CACHE_PATH=/app/data/dhan_access_token.json

TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_BOT_TOKEN=
TELEGRAM_SESSION_NAME=veda_telegram
TELEGRAM_SESSION_DIR=/app/data/telegram
TELEGRAM_CHANNELS=
TELEGRAM_INGEST_LIMIT=50

X_BEARER_TOKEN=
X_USERNAMES=

ENABLE_LIVE_TRADING=false
ENABLE_PAPER_TRADING=true
PAPER_TRADING_SYMBOLS=NIFTY,BANKNIFTY
PAPER_TRADING_TIMEFRAME=5m
PAPER_TRADING_INTERVAL_SECONDS=300
PAPER_TRADING_CANDLE_LIMIT=250
PAPER_TRADING_QUANTITY=1
PAPER_MAX_OPEN_TRADES_PER_SYMBOL=1
PAPER_TRADE_COOLDOWN_CANDLES=5
PAPER_EXIT_MODE=author_part_book_trail
PAPER_PART_BOOK_R_MULTIPLE=1.0
PAPER_PART_BOOK_FRACTION=0.5
PAPER_TRAIL_LOOKBACK_CANDLES=3
PAPER_TRADING_ON_START=false
GLOBAL_KILL_SWITCH=false
MAX_DAILY_DRAWDOWN_PCT=1.0

BACKUP_DIR=/backups
