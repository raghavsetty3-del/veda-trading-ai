APP_ENV=dev
APP_NAME=veda-trading-ai
APP_SECRET_KEY=change-me

POSTGRES_DB=veda
POSTGRES_USER=veda
POSTGRES_PASSWORD=veda_password
DATABASE_URL=postgresql+psycopg://veda:veda_password@postgres:5432/veda

REDIS_URL=redis://redis:6379/0
CHROMA_HOST=chroma
CHROMA_PORT=8000

OPENAI_API_KEY=
OPENAI_EXTRACTION_ENABLED=false
OPENAI_EXTRACTION_MODEL=gpt-4.1-mini

BLOG_FEEDS=
BLOG_DISCOVERY_URLS=
BLOG_INGEST_INTERVAL_SECONDS=3600
BLOG_INGEST_LIMIT=20
BLOG_INGEST_ON_START=false

# Semicolon-separated: SYMBOL|timeframe|http(s), file://, or local CSV path
MARKET_DATA_SOURCES=
MARKET_DATA_INGEST_INTERVAL_SECONDS=900
MARKET_DATA_INGEST_LIMIT=5000
MARKET_DATA_INGEST_ON_START=false

TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_NAME=veda_telegram
TELEGRAM_CHANNELS=

X_BEARER_TOKEN=
X_USERNAMES=

ENABLE_LIVE_TRADING=false
ENABLE_PAPER_TRADING=true
PAPER_TRADING_SYMBOLS=NIFTY,BANKNIFTY
PAPER_TRADING_TIMEFRAME=5m
PAPER_TRADING_INTERVAL_SECONDS=300
PAPER_TRADING_CANDLE_LIMIT=50
PAPER_TRADING_QUANTITY=1
PAPER_TRADING_ON_START=false
GLOBAL_KILL_SWITCH=false
MAX_DAILY_DRAWDOWN_PCT=1.0

BACKUP_DIR=/backups
